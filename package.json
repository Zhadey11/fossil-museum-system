{
  "name": "fossil-museum-system",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:all": "concurrently -n backend,web -c cyan,magenta \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "verify:contracts": "node backend/scripts/verify-contracts.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
