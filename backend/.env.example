PORT=4000
# Orígenes del frontend (coma si hay varios). localhost y 127.0.0.1 mismo puerto se amplían solos en app.js.
FRONTEND_URL=http://localhost:3000
JWT_SECRET=cambiar_por_un_secreto_largo_en_produccion

# true = misma conexion que Azure Data Studio con Windows Authentication (usuario Windows actual)
# false = usuario y contrasena SQL (sa u otro login SQL)
DB_USE_WINDOWS_AUTH=true

# En SSMS / Azure Data Studio: "." o (local) = instancia por defecto; se convierte a (local) en el driver
DB_SERVER=.
DB_DATABASE=FosilesDB

# Solo si DB_USE_WINDOWS_AUTH=false
DB_USER=sa
DB_PASSWORD=tu_contraseña

# Vacio = puerto por defecto del driver; o 1433 si tu instancia por defecto escucha ahi
DB_PORT=

# Con usuario SQL, pon true si el servidor exige cifrado (como "Encrypt: Mandatory" en el cliente)
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
