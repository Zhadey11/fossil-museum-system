# Copiá a docker/compose.env y ajustá (opcional). Docker Compose carga este archivo si existe:
#   docker compose -f docker/docker-compose.yml --env-file docker/compose.env up
# O exportá las variables en la shell antes de `docker compose up`.

# Contraseña del usuario sa en el contenedor SQL (misma que usará el backend como DB_PASSWORD).
MSSQL_SA_PASSWORD=FossilMuseum123!

# Nombre de la base (debe coincidir con los scripts en database/).
DB_DATABASE=FosilesDB

# URLs si accedés al front desde otro host (CORS / enlaces en correos).
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:4000
