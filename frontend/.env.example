# URL del backend Express (sin barra final)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Opcional: nombres de archivo en backend/images/instalaciones/ para la galería de portada (coma-separados)
# NEXT_PUBLIC_GALERIA_INSTALACIONES=sala1.jpg,sala2.png,...

# Dev: si abrís el front por IP (http://192.168.x.x:3000), permití ese origen para /_next/* y evitá el aviso de Next
# NEXT_ALLOWED_DEV_ORIGINS=http://192.168.51.68:3000
